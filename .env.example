# Copy to .env locally — never commit real secrets.
# Local demo is unauthenticated and loopback-only.

PORT=8787
# HOST=127.0.0.1
# BIND_HOST=127.0.0.1
# ALLOW_PUBLIC_BIND=true   # required to bind 0.0.0.0 / non-loopback (dangerous for unauthenticated demo)

# Optional: shared TROZLANIO Postgres (schema trozbot). Leave unset for in-memory tickets + audit.
# Never put production credentials in git. Use TROZLANIO secret conventions.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Host→orchestrator service token (server-to-server only). Same value on TROZLANIO host.
# When set, create_ticket identity is accepted only via:
#   X-Trozbot-Host-Token / X-Trozbot-Tenant-Id / X-Trozbot-User-Id
# Never commit a real token. Browsers must not receive this secret.
# TROZBOT_HOST_SERVICE_TOKEN=

# Web
# ORCHESTRATOR_URL=http://127.0.0.1:8787

# Voice (stub STT/TTS when unset)
# STT_API_KEY=
# TTS_API_KEY=
# TROZBOT_LIVE_MEDIA=1   # refused until vendor adapter ships
