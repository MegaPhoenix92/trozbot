{
  "name": "trozbot",
  "private": true,
  "version": "0.1.0",
  "description": "TROZBOT — robot voice support concierge (Wave 1 local slice)",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "dev:orchestrator": "pnpm --filter @trozbot/orchestrator dev",
    "start:orchestrator": "pnpm --filter @trozbot/orchestrator start",
    "dev:web": "pnpm --filter @trozbot/web dev",
    "start:web": "pnpm --filter @trozbot/web start",
    "dev:voice": "pnpm --filter @trozbot/voice-gateway dev",
    "start:voice": "pnpm --filter @trozbot/voice-gateway start",
    "k8s:dry-run": "kubectl apply -k deploy/k8s --dry-run=client",
    "k8s:validate": "node deploy/k8s/validate.test.mjs"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
